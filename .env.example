# =============================================================================
# Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# These values are referenced in docker-compose.yml using ${VARIABLE} syntax.
# =============================================================================

# DockerHub username for image pull/push
DOCKERHUB_USERNAME=yourdockerhubusername

# Image tag (e.g., latest, v1.0.0, git-sha)
TAG=latest

# Public-facing URL where the app is accessible
# On EC2, use the public IP or domain: http://your-ec2-public-ip
# Leave empty to use the browser's current origin
PUBLIC_URL=

# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
